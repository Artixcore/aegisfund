NODE_ENV=development
# HTTP port for the Express server (default 3000)
PORT=3000

# -----------------------------------------------------------------------------
# Auth / sessions (JWT cookie)
# -----------------------------------------------------------------------------
# Secret for signing session JWTs (HS256). Use a long random string; same value
# must be used by every instance that verifies cookies.
# Generate: openssl rand -base64 48
JWT_SECRET=
# Issuer claim for session tokens (must match verification)
JWT_ISSUER=aegis
# When true, enables GET /api/auth/dev-login in production; in development it
# defaults on unless set to false.
AUTH_DEV_LOGIN=
# Optional: user openId that receives admin role on upsert (see server/db.ts)
OWNER_OPEN_ID=

# -----------------------------------------------------------------------------
# Database (MySQL)
# -----------------------------------------------------------------------------
# Preferred: single URL. Special characters in the password must be
# percent-encoded (see shared/mysqlUrl.ts).
# Example: mysql://user:encodedpass@host:3306/dbname
DATABASE_URL=
# Alternative to DATABASE_URL:
DB_HOST=
DB_PORT=3306
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
# Scripts / RDS: set DB_SSL=1 for TLS; DB_SSL_REJECT_UNAUTHORIZED=1 to verify cert
DB_SSL=
DB_SSL_REJECT_UNAUTHORIZED=

# -----------------------------------------------------------------------------
# Field encryption (PII / MFA / KYC columns at rest)
# -----------------------------------------------------------------------------
# Required in production when persisting encrypted user fields.
# 32 bytes as 64 hex characters OR base64 (44 chars). See server/fieldEncryption.ts
# Generate: openssl rand -hex 32
DATABASE_FIELD_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Blockchain / balances
# -----------------------------------------------------------------------------
# Bitcoin REST API base (e.g. Esplora-compatible)
BTC_REST_API_BASE=
# Ethereum JSON-RPC URL (Infura, Alchemy, self-hosted)
ETH_RPC_URL=
# Solana JSON-RPC URL
SOL_RPC_URL=
# Optional: Etherscan API v2 key when not using ETH_RPC_URL for ETH balance
ETHERSCAN_API_KEY=
# Etherscan chain id (default 1 mainnet)
ETHERSCAN_CHAIN_ID=1

# -----------------------------------------------------------------------------
# Market data gateway (Yahoo mirror / Connect-style API)
# -----------------------------------------------------------------------------
AEGIS_DATA_API_URL=
AEGIS_DATA_API_KEY=
# Legacy aliases (same meaning as AEGIS_* in code)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# -----------------------------------------------------------------------------
# TradeWatch REST (quotes — not order execution)
# -----------------------------------------------------------------------------
# API key from https://tradewatch.io — used for market.* tRPC routes
TRADEWATCH_API_KEY=
# Override only for staging; production default is https://api.tradewatch.io
TRADEWATCH_BASE_URL=

# -----------------------------------------------------------------------------
# LLM — primary OpenAI-compatible settings
# -----------------------------------------------------------------------------
# Base URL without path (e.g. https://api.openai.com/v1)
LLM_BASE_URL=https://api.openai.com/v1
# Default chat model id when no provider override applies
LLM_MODEL=gpt-4o-mini
# Optional explicit key; if empty, OPENAI_API_KEY / BUILT_IN_FORGE_API_KEY are used
LLM_API_KEY=
# Set true if your API requires max_completion_tokens instead of max_tokens
LLM_PREFER_MAX_COMPLETION_TOKENS=

# -----------------------------------------------------------------------------
# LLM — OpenAI (also used when routing selects openai provider)
# -----------------------------------------------------------------------------
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# LLM — Google Gemini (when routing selects gemini)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
# Alias accepted in code
GOOGLE_API_KEY=
GEMINI_LLM_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# LLM — xAI Grok (when routing selects grok)
# -----------------------------------------------------------------------------
XAI_API_KEY=
GROK_API_KEY=
XAI_LLM_MODEL=grok-2-latest
GROK_LLM_MODEL=

# -----------------------------------------------------------------------------
# LLM — DeepSeek (when routing selects deepseek)
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_LLM_MODEL=deepseek-chat

# -----------------------------------------------------------------------------
# LLM — advanced (optional)
# -----------------------------------------------------------------------------
# Single provider id, e.g. openai | gemini | grok | deepseek | legacy
LLM_DEFAULT_PROVIDER=
# Comma-separated fallback order, e.g. grok,openai
LLM_FALLBACK_PROVIDERS=
# JSON map of agent type to provider, e.g. {"crypto_monitoring":"grok"}
LLM_AGENT_ROUTING=

# -----------------------------------------------------------------------------
# KYC automation
# -----------------------------------------------------------------------------
# auto | llm | rules — see server/_core/env.ts
KYC_VERIFICATION_MODE=auto
# Optional vision model override (OpenAI-compatible)
KYC_LLM_MODEL=openai
# Max Hamming distance for selfie diversity; 0 or off to disable server check
KYC_SELFIE_POSE_MAX_HAMMING=10

# -----------------------------------------------------------------------------
# Storage — S3 (KYC uploads when bucket + public base URL set)
# -----------------------------------------------------------------------------
S3_BUCKET=
AWS_S3_BUCKET=
S3_PUBLIC_BASE_URL=
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=
# MinIO or custom S3-compatible endpoint (leave empty for AWS)
S3_ENDPOINT=
# Standard AWS SDK credentials if not using instance role:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Storage — local KYC files (alternative to S3)
# -----------------------------------------------------------------------------
# Absolute or repo-relative directory; requires PUBLIC_APP_URL for links
KYC_LOCAL_STORAGE_DIR=
# Public origin of this app, no trailing slash (e.g. http://localhost:3000)
PUBLIC_APP_URL=

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
# Optional HTTPS webhook (JSON POST) for owner-facing alerts
NOTIFICATION_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Messaging
# -----------------------------------------------------------------------------
# In production, relay messages require ciphertext unless set to false
MESSAGES_REQUIRE_CIPHERTEXT=

# -----------------------------------------------------------------------------
# Relay server (npm run relay) — optional
# -----------------------------------------------------------------------------
RELAY_PORT=3456
# Shared secret between app and relay; generate: openssl rand -hex 32
RELAY_SHARED_SECRET=

# -----------------------------------------------------------------------------
# Build / deploy metadata (optional — CI)
# -----------------------------------------------------------------------------
BUILD_ID=
VERCEL_GIT_COMMIT_SHA=
GITHUB_SHA=
