# Session signing (required for login)
JWT_SECRET=123baff1c341cc6a4f0b79faeb286faa6f1edee752eb2a4cc9d008f2ec492241
# Optional issuer string embedded in session JWTs
JWT_ISSUER=aegis-fund

# First user with this openId becomes admin (matches dev-login ?openId=...)
OWNER_OPEN_ID=

# Dev login: GET /api/auth/dev-login — default on in development, off in production
AUTH_DEV_LOGIN=

# Database (one MySQL per deployment — not a shared SaaS DB)
# With Docker: npm run db:up, then npm run db:migrate
# Without Docker: install MySQL 8 locally, create DB/user (see npm run db:up), then db:migrate
MYSQL_DATABASE=aegis_fund
MYSQL_USER=aegis
MYSQL_PASSWORD=aegis_local
MYSQL_ROOT_PASSWORD=aegis_root_local
# Optional host port if 3306 is taken
# MYSQL_PORT=3306
# URL must match MYSQL_* above (use 127.0.0.1 when the app runs on the host)
DATABASE_URL=mysql://aegis:aegis_local@127.0.0.1:3306/aegis_fund

# Data gateway (YahooFinance CallApi, maps proxy, storage proxy, etc.)
AEGIS_DATA_API_URL=
AEGIS_DATA_API_KEY=

# OpenAI-compatible chat (default base: https://api.openai.com)
LLM_BASE_URL=
LLM_API_KEY=

# Optional: POST { title, content } JSON for owner alerts (KYC, price alerts)
NOTIFICATION_WEBHOOK_URL=

# Self-hosted chain access
BTC_REST_API_BASE=
ETH_RPC_URL=
SOL_RPC_URL=
ETHERSCAN_API_KEY=

# Dev-only: seed placeholder wallet rows for new users
DEMO_WALLET_SEEDING=

# --- Decentralized P2P (Messages page) ---
# WebSocket URL for optional relay (`npm run relay` → default ws://127.0.0.1:3456/ws)
VITE_P2P_RELAY_URL=
# Shared secret for relay mailbox + optional gating (must match RELAY_SHARED_SECRET on relay)
VITE_P2P_RELAY_SECRET=
# JSON array of RTCIceServer objects, e.g. [{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:...","username":"u","credential":"p"}]
VITE_P2P_ICE_SERVERS=
# Multipart upload endpoint returning JSON { "cid": "..." } for encrypted file blobs
VITE_P2P_IPFS_UPLOAD_URL=
# Optional Bearer token for pinning API
VITE_P2P_IPFS_TOKEN=

# Relay process (separate from main app)
RELAY_PORT=3456
RELAY_SHARED_SECRET=

# Client: override login redirect (default /api/auth/dev-login)
VITE_LOGIN_URL=
# When this network already registered, append to VITE_LOGIN_URL (e.g. screen_hint=login for Auth0)
VITE_LOGIN_LOGIN_ONLY_QUERY=

