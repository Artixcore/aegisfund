# =============================================================================
# Aegis Fund — environment template
# =============================================================================
# Copy to `.env` and fill in values. Do not commit `.env` or real secrets.
#
# -----------------------------------------------------------------------------
# Generating secrets (run in a terminal; use the same machine you trust for prod)
# -----------------------------------------------------------------------------
#
# JWT_SECRET — HMAC key for session cookies (use a long random string; 64 hex chars is typical)
#   openssl rand -hex 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# DATABASE_FIELD_ENCRYPTION_KEY — AES-256-GCM for KYC/MFA/user PII at rest (required in production)
#   Option A (64 hex characters):
#     openssl rand -hex 32
#   Option B (44-char base64, decodes to exactly 32 bytes — paste without newlines):
#     openssl rand -base64 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# RELAY_SHARED_SECRET / VITE_P2P_RELAY_SECRET — shared string; must match between relay and client build
#   openssl rand -hex 32
#
# API keys (obtain from vendors; do not generate locally):
#   ETHERSCAN_API_KEY — https://etherscan.io/apis (free tier available)
#   LLM_API_KEY — OpenAI or any OpenAI-compatible provider (see LLM_BASE_URL)
#   AEGIS_DATA_API_KEY — your data gateway / Forge deployment
#   VITE_FRONTEND_FORGE_API_KEY — if you use Maps/Forge on the client (build-time)
#
# -----------------------------------------------------------------------------
# Production checklist (see also README “Deployment”)
# -----------------------------------------------------------------------------
#   [ ] DATABASE_URL (or DB_*) reachable with TLS if required by host
#   [ ] JWT_SECRET set to a new random value (not the dev example below)
#   [ ] DATABASE_FIELD_ENCRYPTION_KEY set (64 hex or 32-byte base64)
#   [ ] AUTH_DEV_LOGIN=false
#   [ ] ETHERSCAN_API_KEY, LLM_* / AEGIS_DATA_* as needed for features you enable
#   [ ] VITE_* set at build time wherever you run `npm run build` (DigitalOcean: BUILD_TIME on the web component)
#
# =============================================================================

# --- Session / auth (required for login) ---
# Generate JWT_SECRET: openssl rand -hex 32
JWT_SECRET=
JWT_ISSUER=aegis-fund

# First user with this openId gets admin (e.g. dev-login ?openId=...). Set for your owner account in prod.
OWNER_OPEN_ID=

# GET /api/auth/dev-login — in development defaults ON unless AUTH_DEV_LOGIN=false; in production defaults OFF unless true.
# Production: use false unless you explicitly want dev login on your deploy.
AUTH_DEV_LOGIN=

# --- Database (one MySQL per deployment) ---
# Local Docker: npm run db:up, then npm run db:migrate
# URL-encode special characters in passwords (% → %25, @ → %40) or use DB_* vars below.
MYSQL_DATABASE=aegis_fund
MYSQL_USER=aegis
MYSQL_PASSWORD=aegis_local
MYSQL_ROOT_PASSWORD=aegis_root_local
# MYSQL_PORT=3306

DATABASE_URL=mysql://aegis:aegis_local@127.0.0.1:3306/aegis_fund

# --- Data gateway (storage proxy, Yahoo Finance proxy, maps, etc.) ---
AEGIS_DATA_API_URL=
AEGIS_DATA_API_KEY=

# --- TradeWatch (unified market data: crypto, forex, stocks, indices, commodities) ---
# API key: https://dash.tradewatch.io/api-keys — used by server-only `market.*` tRPC routes.
TRADEWATCH_API_KEY=
# Optional; default https://api.tradewatch.io
# TRADEWATCH_BASE_URL=

# --- LLM (multi-provider + legacy OpenAI-compatible URL) ---
# Legacy mode: LLM_API_KEY + optional LLM_BASE_URL + LLM_MODEL (single OpenAI-compatible endpoint).
# Multi-provider: set LLM_DEFAULT_PROVIDER and per-provider keys; optional LLM_FALLBACK_PROVIDERS and LLM_AGENT_ROUTING.
#
# Providers: legacy | openai | gemini | grok | deepseek
# LLM_DEFAULT_PROVIDER empty or unset defaults to legacy (LLM_* vars above).
LLM_DEFAULT_PROVIDER=
# After the primary fails, try these (comma-separated), e.g. grok,openai
LLM_FALLBACK_PROVIDERS=
# JSON map agent → provider, e.g. {"crypto_monitoring":"grok","executive_briefing":"openai"}
LLM_AGENT_ROUTING=

# Legacy / custom OpenAI-compatible proxy (LiteLLM, OpenRouter, etc.)
# Examples: empty = api.openai.com | https://api.openai.com | Gemini compat: https://generativelanguage.googleapis.com/v1beta/openai
LLM_BASE_URL=
LLM_API_KEY=
# Default when unset: gpt-4o-mini (matches default host api.openai.com). Set e.g. gemini-2.5-flash if LLM_BASE_URL is Gemini-compatible.
LLM_MODEL=

# OpenAI (https://api.openai.com) — also used if you rely on legacy without LLM_BASE_URL override.
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini

# Google Gemini — OpenAI-compatible API (AI Studio key); see https://ai.google.dev/gemini-api/docs/openai
GEMINI_API_KEY=
# GOOGLE_API_KEY=
GEMINI_LLM_MODEL=gemini-2.5-flash

# xAI Grok (https://api.x.ai)
XAI_API_KEY=
# GROK_API_KEY=
XAI_LLM_MODEL=grok-2-latest
# GROK_LLM_MODEL=

# DeepSeek (https://api.deepseek.com)
DEEPSEEK_API_KEY=
DEEPSEEK_LLM_MODEL=deepseek-chat

# Optional: POST JSON { title, content } for owner alerts (KYC, price alerts, scheduled AI agents)
NOTIFICATION_WEBHOOK_URL=

# --- Chain / indexers ---
# ETHERSCAN_API_KEY: create at https://etherscan.io/apis (used for ETH balance only when ETH_RPC_URL is unset)
ETHERSCAN_API_KEY=
# Etherscan API v2 chain id for balance fallback: 1 = Ethereum mainnet, 11155111 = Sepolia, etc.
ETHERSCAN_CHAIN_ID=1
BTC_REST_API_BASE=
ETH_RPC_URL=
SOL_RPC_URL=

# --- Field encryption (production writes to sensitive columns) ---
# Generate: openssl rand -hex 32   OR   openssl rand -base64 32
# Must be 64 hex chars OR 44-char base64 representing 32 bytes.
DATABASE_FIELD_ENCRYPTION_KEY=

# Relay messages: in production, require client ciphertext unless set to false
MESSAGES_REQUIRE_CIPHERTEXT=

# --- Client-only (Vite; must be present when you run `npm run build` for production bundles) ---
# Maps / Frontend Forge (optional)
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=
# Google Cloud Map ID for MapView (vector / advanced markers). Optional; omit for classic raster tiles.
VITE_GOOGLE_MAPS_MAP_ID=

# Login redirect overrides (optional; default uses /api/auth/dev-login in dev)
VITE_LOGIN_URL=
VITE_LOGIN_LOGIN_ONLY_QUERY=

# --- P2P / Messages page (optional) ---
# WebSocket relay: npm run relay (default ws://127.0.0.1:3456/ws). Generate shared secret: openssl rand -hex 32
VITE_P2P_RELAY_URL=
VITE_P2P_RELAY_SECRET=
# JSON array of RTCIceServer, e.g. [{"urls":"stun:stun.l.google.com:19302"}]
VITE_P2P_ICE_SERVERS=
VITE_P2P_IPFS_UPLOAD_URL=
VITE_P2P_IPFS_TOKEN=

RELAY_PORT=3456
# Must match VITE_P2P_RELAY_SECRET (generate once, paste both places)
RELAY_SHARED_SECRET=

# --- DigitalOcean App Platform ---
# Spec: .do/app.yaml — DATABASE_URL via ${aegis-mysql.DATABASE_URL}; migration job runs db:migrate before deploy.
# Add JWT_SECRET, DATABASE_FIELD_ENCRYPTION_KEY, LLM_API_KEY, ETHERSCAN_API_KEY as encrypted RUN_TIME secrets in the DO UI.
# Set VITE_* on the web component with BUILD_TIME or RUN_AND_BUILD_TIME so Vite inlines them during build.
